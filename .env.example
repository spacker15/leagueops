# Supabase — copy from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — used for QR code generation and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public results site URL — used for registration links and QR codes
# Set this to the deployed public-results app domain in Vercel (e.g., https://leagueops-live.vercel.app)
# The /e/[slug]/register route lives in apps/public-results, deployed at a different domain from the admin app
NEXT_PUBLIC_PUBLIC_RESULTS_URL=http://localhost:3001

# Weather (optional — uses mock data if missing)
OPENWEATHER_API_KEY=your-openweather-api-key-here

# Google Maps (optional — venue search in event creation)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Upstash Redis — used for rate limiting (Phase 03)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
